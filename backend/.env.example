# Copy this file to .env and fill in your values
SECRET_KEY=django-insecure-replace-with-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (uncomment for PostgreSQL)
# DATABASE_URL=postgres://user:password@localhost:5432/jobhub

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email (console backend for dev, smtp for production)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@jobhub.com
